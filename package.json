{
  "name": "@nlace/ui-kit",
  "publishConfig": {
    "access": "public"
  },
  "version": "1.5.0",
  "description": "NLACE Design System — tokens CSS, Tailwind preset y componentes React",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./tokens": "./src/tokens/tokens.css",
    "./preset": "./src/tailwind-preset.js"
  },
  "files": [
    "dist",
    "src/tokens",
    "src/tailwind-preset.js"
  ],
  "scripts": {
    "build": "vite build",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "nlace",
    "design-system",
    "tailwind",
    "ui-kit"
  ],
  "license": "UNLICENSED",
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.4",
    "tailwindcss": "^3.4.0",
    "vite": "^7.3.1"
  }
}
